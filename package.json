{
  "name": "scope-kanban",
  "version": "0.1.5",
  "description": "Local-first kanban for projects, epics, stories, and bugs — built for agents. CLI + web UI + MCP server.",
  "type": "module",
  "bin": {
    "scope": "./bin/scope.js"
  },
  "main": "./src/cli.js",
  "scripts": {
    "start": "node ./bin/scope.js",
    "ui": "node ./bin/scope.js ui",
    "serve": "node ./bin/scope.js serve",
    "release": "bash ./scripts/release.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.3.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "express": "^4.21.0",
    "open": "^10.1.0",
    "zod": "^4.4.3"
  },
  "files": [
    "bin",
    "src",
    "LICENSE"
  ],
  "keywords": [
    "kanban",
    "cli",
    "mcp",
    "agent",
    "task-management",
    "project-management",
    "sqlite",
    "github-projects",
    "tickets",
    "epics"
  ],
  "license": "MIT",
  "author": {
    "name": "Brianna Doubt",
    "email": "bri@briannadoubt.com",
    "url": "https://github.com/briannadoubt"
  },
  "homepage": "https://github.com/briannadoubt/scope",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/briannadoubt/scope.git"
  },
  "bugs": {
    "url": "https://github.com/briannadoubt/scope/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
