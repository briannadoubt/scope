{
  "name": "scope-kanban",
  "version": "0.8.3",
  "description": "Local-first kanban for projects, epics, stories, and bugs — built for agents. CLI + web UI.",
  "type": "module",
  "bin": {
    "scope": "./bin/scope.js"
  },
  "main": "./src/index.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/index.js"
    },
    "./cli": {
      "types": "./types/cli.d.ts",
      "default": "./src/cli.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "start": "node ./bin/scope.js",
    "serve": "node ./bin/scope.js serve",
    "test": "node --test --import=./test/setup.js test/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-exclude='test/**' --test-coverage-exclude='src/web/**' --import=./test/setup.js test/*.test.js",
    "build:types": "tsc -p tsconfig.types.json",
    "prepack": "npm run build:types",
    "release": "bash ./scripts/release.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.10.0",
    "bonjour-service": "^1.4.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "express": "^4.21.0",
    "node-forge": "^1.4.0",
    "open": "^10.1.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "files": [
    "bin",
    "src",
    "types",
    "plugins",
    "skills",
    "LICENSE"
  ],
  "keywords": [
    "kanban",
    "cli",
    "agent",
    "task-management",
    "project-management",
    "sqlite",
    "github-projects",
    "tickets",
    "epics"
  ],
  "license": "MIT",
  "author": {
    "name": "Brianna Doubt",
    "email": "bri@briannadoubt.com",
    "url": "https://github.com/briannadoubt"
  },
  "homepage": "https://github.com/briannadoubt/scope",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/briannadoubt/scope.git"
  },
  "bugs": {
    "url": "https://github.com/briannadoubt/scope/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
